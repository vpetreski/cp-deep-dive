{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cp-deep-dive.dev/schemas/solve-response.schema.json",
  "title": "SolveResponse",
  "description": "Result payload for GET /solution/{jobId}. The schedule is present only for feasible, optimal, or partially-solved jobs.",
  "type": "object",
  "required": ["jobId", "status"],
  "additionalProperties": false,
  "properties": {
    "jobId": {
      "type": "string",
      "minLength": 1
    },
    "instanceId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "queued",
        "running",
        "feasible",
        "optimal",
        "infeasible",
        "unknown",
        "timeout",
        "cancelled",
        "modelInvalid",
        "error"
      ]
    },
    "schedule": {
      "$ref": "schedule.schema.json"
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "additionalProperties": false,
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["hard", "soft"] },
          "nurseId": { "type": "string" },
          "day": { "type": "integer", "minimum": 0 },
          "penalty": { "type": "number" }
        }
      }
    },
    "objective": {
      "type": "number"
    },
    "bestBound": {
      "type": "number"
    },
    "gap": {
      "type": "number"
    },
    "solveTimeSeconds": {
      "type": "number",
      "minimum": 0
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "endedAt": {
      "type": "string",
      "format": "date-time"
    },
    "error": {
      "type": "string"
    }
  }
}
